# ════════════════════════════════════════════════
#   KAIROS-HEDGE — API KEYS CONFIGURATION
#   Fill all values below, then rename to .env
# ════════════════════════════════════════════════

# ── GROQ (Primary LLM — FREE) ──────────────────
# 1. Go to: https://console.groq.com
# 2. Sign up free → API Keys → Create New Key
GROQ_API_KEY=gsk_your_key_here

# ── GOOGLE GEMINI (Fallback LLM — FREE) ────────
# 1. Go to: https://aistudio.google.com
# 2. Sign in → Get API Key → Create API Key
GEMINI_API_KEY=AIza_your_key_here

# ── OPENROUTER (Fallback LLM — FREE credits) ───
# 1. Go to: https://openrouter.ai
# 2. Sign up → API Keys → Create Key
OPENROUTER_API_KEY=sk-or-your_key_here

# ── OLLAMA (Local fallback — NO KEY NEEDED) ────
# 1. Download from: https://ollama.com
# 2. Run in terminal: ollama pull llama3
# 3. Leave values below as-is
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── TELEGRAM (FREE) ────────────────────────────
# 1. Open Telegram → Search @BotFather
# 2. Send /newbot → follow steps → copy token below
# 3. Start your bot → visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 4. Send any message to your bot
# 5. Copy the number from: "chat":{"id": XXXXXXX}
TELEGRAM_BOT_TOKEN=7000000000:AAFxxx_your_token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# ── GOOGLE SHEETS (FREE — optional) ───────────
# 1. Go to: https://console.cloud.google.com
# 2. New Project → Enable "Google Sheets API"
# 3. IAM → Service Accounts → Create → Download JSON
# 4. Save JSON file as: credentials/google_service_account.json
# 5. Open your Google Sheet → Share with service account email
# 6. Copy Sheet ID from URL: /spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google_service_account.json
GOOGLE_SHEET_ID=your_sheet_id_from_url
